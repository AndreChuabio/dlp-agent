# MediGuard DLP — secrets file template
# Copy this to secrets/local.secrets (or your-name.secrets) and fill in real values.
# This file (example.secrets) is safe to commit — it has no real values.
# Files matching *.secrets (except example.secrets) are gitignored.
#
# Set SECRETS_FILE=/path/to/your.secrets in your environment, or pass
# secrets_file= to any MCP tool that accepts it.
#
# Usage in workflow templates: {{KEY_NAME}}
# Example: "Run onboarding for patient {{TEST_PATIENT_MRN}}"
# The MCP server substitutes values locally — they never reach an LLM.

# ── Ticket / session references ───────────────────────────────────────────
# Map ticket IDs to session slugs so you can say "replay ticket-1234"
# without retyping session names.
TICKET_1234=acme-onboard-bug
TICKET_5678=cholesterol-triage-miss

# ── Test patient data (local debugging only) ──────────────────────────────
TEST_PATIENT_MRN=
TEST_PATIENT_DOB=
TEST_PATIENT_PHONE=
TEST_PATIENT_NAME=

# ── Client / account identifiers ─────────────────────────────────────────
CLIENT_ACME_ID=
CLIENT_ACME_API_KEY=

# ── Internal API keys (never share these) ────────────────────────────────
INTERNAL_API_KEY=
STAGING_DB_URL=

# ── Any other values you want auto-redacted from text sent to LLMs ────────
# Add as KEY=value — the DLP scanner will catch them automatically.
