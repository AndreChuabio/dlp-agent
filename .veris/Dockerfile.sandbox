ARG VERIS_BASE
FROM ${VERIS_BASE}

WORKDIR /agent

# Copy dependency manifest first (for layer caching)
COPY requirements.txt /agent/

# Install dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Copy project code
COPY agent/ /agent/agent/
COPY api/ /agent/api/

# Veris requires ending with WORKDIR /app
WORKDIR /app
