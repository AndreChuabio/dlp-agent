ARG GVISOR_BASE=us-central1-docker.pkg.dev/veris-ai-prod/veris-sandbox/veris-gvisor:latest
FROM ${GVISOR_BASE}

WORKDIR /agent

# Install build tools needed for native packages
RUN apt-get update && apt-get install -y gcc portaudio19-dev && rm -rf /var/lib/apt/lists/*

# Copy project code
COPY agent/ /agent/agent/
COPY api/ /agent/api/
COPY requirements.txt /agent/

# Install only what the API server needs — skip audio packages
RUN pip install --no-cache-dir \
    anthropic \
    openai \
    fastapi \
    uvicorn \
    python-dotenv \
    requests

WORKDIR /agent
